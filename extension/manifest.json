{
  "manifest_version": 3,
  "name": "Taskative — Quick Task",
  "version": "1.0.1",
  "description": "Select any text on a webpage and turn it into a Taskative task with one click.",
  "permissions": ["contextMenus", "storage", "activeTab", "notifications"],
  "host_permissions": [
    "https://taskativeapp.com/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
